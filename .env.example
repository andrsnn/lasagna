OLLAMA_API_KEY=
# Admin password. The first sign-in with ADMIN_EMAIL + TEMP_PASS lazily
# creates the admin user record (PBKDF2-hashed) in Redis; after that,
# changing TEMP_PASS in env has no effect on the admin's password.
TEMP_PASS=

# Email of the admin account. First login with this email + TEMP_PASS
# bootstraps the admin user. Also gates /admin/* — non-admin signups
# can't reach those pages. Defaults to admin@example.com when unset.
ADMIN_EMAIL=

# HMAC key used to sign session cookies. Falls back to TEMP_PASS if unset,
# but setting it explicitly to a long random string lets you rotate
# TEMP_PASS (or any user's password) without invalidating sessions.
SESSION_SECRET=

# Passkeys / WebAuthn (all optional). By default the Relying Party ID and
# expected origin are derived from the incoming request's Host header, so
# passkeys work out of the box on localhost, *.fly.dev, *.vercel.app, and any
# custom domain. Set these only if the browser-visible origin differs from the
# Host header the server sees (an unusual proxy setup):
#   RP_ID     — registrable domain the passkey is bound to (no scheme/port), e.g. example.com
#   RP_ORIGIN — full expected origin, e.g. https://example.com
#   RP_NAME   — service name shown in the OS passkey prompt (defaults to "Lasagna")
# Passkey credentials are stored in Redis, so UPSTASH_REDIS_* / KV_REST_* below
# must be configured for passkeys to be available.
RP_ID=
RP_ORIGIN=
RP_NAME=

# OpenAI — required for the high-quality "Speak" backend (app/api/tts/route.ts).
# Cheapest model (tts-1) costs ~$0.015 per 1k characters. Without this, the
# Speak action falls back to the browser's speechSynthesis (lower quality).
OPENAI_API_KEY=

# RunPod Serverless — optional second LLM provider. Models with id prefix
# "runpod:" route here instead of Ollama Cloud, hitting the OpenAI-compatible
# endpoint at https://api.runpod.ai/v2/${RUNPOD_ENDPOINT_ID}/openai/v1.
# Both vars must be set for RunPod routing to be active. The svenbrnn/runpod-ollama
# image (and vLLM/SGLang workers) expose this path natively.
# Note: Ollama-Cloud-only built-in tools (web_search, web_fetch) still require
# OLLAMA_API_KEY even when chatting with a runpod: model — they're proxied
# through the Ollama SDK regardless of the chat provider.
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Optional. Override the vision describer model when the user's main chat
# model is a text-only RunPod model and they upload images. Leave empty to
# keep using gemma4:31b on Ollama Cloud (requires OLLAMA_API_KEY). Prefix
# with "runpod:" to use a vision-capable RunPod model instead.
RUNPOD_VISION_DESCRIBER_MODEL=

# Brave Search Images API key — required for the `image_search` tool.
# Get one at https://api.search.brave.com/. The image-search chat toggle is
# only useful when this is set; without it, the tool returns a clean error.
BRAVE_SEARCH_API_KEY=

# Redis — required for resumable chat streams. The app accepts either pair:
#   UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN  (Upstash Marketplace integration)
#   KV_REST_API_URL        + KV_REST_API_TOKEN         (Vercel KV / Marketplace KV)
# Provisioning Upstash for Redis or Vercel KV from your project's Storage tab on Vercel
# auto-injects one of these pairs; no manual copy/paste needed.
# When unset, the chat still works but a closed tab kills the in-flight Ollama call.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
